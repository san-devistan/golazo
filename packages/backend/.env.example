CONVEX_DEPLOYMENT=<deployment-name>
CONVEX_URL=https://<deployment>.convex.cloud
CONVEX_SITE_URL=https://<deployment>.convex.site
SITE_URL=https://golazo.localhost
BETTER_AUTH_TRUSTED_ORIGINS=https://golazo.localhost
STRIPE_SECRET_KEY=rk_test_or_sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SHIPPING_ALLOWED_COUNTRIES=FR

# Optional fallback if the EUR to USD API cannot be reached.
EUR_TO_USD_RATE=1.10

RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Golazo <orders@example.com>
RESEND_DEV_TO_EMAIL=<resend-account-email@example.com>
RESEND_WEBHOOK_SECRET=whsec_...

# Required for signed Cloudinary uploads from the admin UI.
CLOUDINARY_CLOUD_NAME=<cloud-name>
CLOUDINARY_API_KEY=<api-key>
CLOUDINARY_API_SECRET=<api-secret>
